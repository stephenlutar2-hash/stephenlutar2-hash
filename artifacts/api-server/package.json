{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "pnpm run build && node --enable-source-maps ./dist/seed.mjs",
    "seed:rosie": "pnpm run build && node --enable-source-maps ./dist/seed-rosie.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@azure/msal-node": "^5.1.1",
    "@azure/storage-blob": "^12.26.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@szl-holdings/api-zod": "workspace:*",
    "@szl-holdings/db": "workspace:*",
    "@szl-holdings/integrations-openai-ai-server": "workspace:*",
    "@szl-holdings/domain-utils": "workspace:*",
    "@szl-holdings/lyte-types": "workspace:*",
    "applicationinsights": "^3.14.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "pino": "^9",
    "pino-http": "^10",
    "plaid": "^41.4.0",
    "stripe": "^20.4.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
